{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "aviaryName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Bird": {
      "title": "Bird",
      "description": "Bird record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "ringNumber": { "type": "string" },
        "species": { "type": "string" },
        "mutation": { "type": "string" },
        "sex": { "type": "string", "enum": ["Male", "Female", "Unknown"] },
        "birthDate": { "type": "string", "format": "date" },
        "photoURL": { "type": "string" },
        "notes": { "type": "string" },
        "fatherId": { "type": "string" },
        "motherId": { "type": "string" },
        "origin": { "type": "string", "enum": ["Bred by me", "Purchased"] },
        "healthStatus": { "type": "string" },
        "availability": { "type": "string", "enum": ["For Sale", "Bred"] },
        "isForSale": { "type": "boolean" },
        "salePrice": { "type": "number" },
        "publicProfileEnabled": { "type": "boolean" }
      },
      "required": ["ownerId", "species", "ringNumber"]
    },
    "Nest": {
      "title": "Nest",
      "description": "Breeding nest record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "pairId": { "type": "string" },
        "pairName": { "type": "string" },
        "firstEggDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Laying", "Incubating", "Hatching", "Fledging"] },
        "eggsCount": { "type": "integer" },
        "chicksCount": { "type": "integer" },
        "color": { "type": "string" }
      },
      "required": ["ownerId", "pairName"]
    },
    "Mail": {
      "title": "Mail",
      "description": "Email to be sent by Trigger Email extension",
      "type": "object",
      "properties": {
        "to": { "type": "string", "format": "email" },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "text": { "type": "string" },
            "html": { "type": "string" }
          }
        }
      },
      "required": ["to", "message"]
    },
    "ProductionRecord": {
      "title": "Production Record",
      "description": "Breeding results for a bird",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "birdId": { "type": "string" },
        "ownerId": { "type": "string" },
        "year": { "type": "integer" },
        "clutchNumber": { "type": "integer" },
        "eggsCount": { "type": "integer" },
        "hatchedCount": { "type": "integer" },
        "weanedCount": { "type": "integer" },
        "notes": { "type": "string" }
      },
      "required": ["birdId", "ownerId", "year", "clutchNumber"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/birds/{birdId}": {
      "schema": "Bird",
      "description": "Bird records"
    },
    "/nests/{nestId}": {
      "schema": "Nest",
      "description": "Breeding nest records"
    },
    "/mail/{mailId}": {
      "schema": "Mail",
      "description": "Collection for Trigger Email extension"
    },
    "/production/{recordId}": {
      "schema": "ProductionRecord",
      "description": "Breeding results for birds"
    }
  }
}
